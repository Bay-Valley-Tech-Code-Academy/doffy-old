{
  "manifest_version": 2,
  "name": "Job Scraper",
  "version": "1.0",
  "description": "Scrape job postings from websites.",
  "permissions": ["activeTab", "downloads", "tabs"],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jobscraper@yourdomain.com",
      "strict_min_version": "91.0"
    }
  }
}
