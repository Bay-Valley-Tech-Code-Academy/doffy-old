{
"manifest_version": 3,
"name": "Job Scraper",
"version": "1.0",
"description": "Scrape job postings from websites.",
"permissions": ["scripting", "activeTab", "downloads"],
"host_permissions": ["https://*/*", "http://*/*"],
"background": {
  "service_worker": "background.js"
},
"action": {
  "default_popup": "popup.html",
  "default_icon": {
    "16": "icon16.jpg",
    "48": "icon48.jpg",
    "128": "icon128.jpg"
  }
},
"content_scripts": [
  {
    "matches": ["https://*/*", "http://*/*"],
    "js": ["content.js"]
  }
]
}